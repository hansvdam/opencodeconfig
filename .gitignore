# Installed dependencies — OpenCode vendors these into the config dir on demand.
# The custom tools here are dependency-free, so none of this needs tracking.
node_modules/
package.json
package-lock.json
bun.lock

# Migration backups
*.bak

# OS junk
.DS_Store

# Local-only model override (e.g. home machine). Loaded at runtime via
# OPENCODE_CONFIG_CONTENT; never pushed, so colleagues only ever see the
# committed work config in opencode/opencode.json.
local/
