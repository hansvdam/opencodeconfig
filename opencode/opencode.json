{
  "$schema": "https://opencode.ai/config.json",

  "share": "disabled",
  "autoupdate": false,

  "enabled_providers": ["localllm"],
  "disabled_providers": [
    "opencode", "anthropic", "openai", "google",
    "google-generative-ai", "azure", "bedrock", "openrouter",
    "mistral", "groq", "xai", "deepseek", "perplexity",
    "github-copilot", "zenmux", "gitlab", "nvidia", "nebius",
    "huggingface", "together", "fireworks", "cerebras"
  ],

  "provider": {
    "localllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local LLM (vllm @ 192.168.0.5)",
      "options": {
        "baseURL": "http://192.168.0.5:8000/v1",
        "timeout": false,
        "chunkTimeout": 3600000
      },
      "models": {
        "Qwen/Qwen3-Coder-Next-FP8": {
          "name": "Qwen3 Coder Next (local)",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    }
  },

  "model": "localllm/mlx-community/Qwen3-Coder-Next-6bit",
  "small_model": "localllm/mlx-community/Qwen3-Coder-Next-6bit",

  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "deny"
  }
}
