{
  "$schema": "https://opencode.ai/config.json",

  "share": "disabled",
  "autoupdate": false,

  "enabled_providers": ["localllm"],
  "disabled_providers": [
    "opencode", "anthropic", "openai", "google",
    "google-generative-ai", "azure", "bedrock", "openrouter",
    "mistral", "groq", "xai", "deepseek", "perplexity",
    "github-copilot", "zenmux", "gitlab", "nvidia", "nebius",
    "huggingface", "together", "fireworks", "cerebras"
  ],

  "provider": {
    "localllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local LLM (vllm @ 192.168.0.5)",
      "options": {
        "baseURL": "http://192.168.0.5:8000/v1",
        "timeout": false,
        "chunkTimeout": 3600000
      },
      "models": {
        "nvidia/Qwen3.6-35B-A3B-NVFP4": {
          "name": "Qwen3.6-35B-A3B-NVFP4",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },

  "model": "localllm/nvidia/Qwen3.6-35B-A3B-NVFP4",
  "small_model": "localllm/nvidia/Qwen3.6-35B-A3B-NVFP4",

  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "deny"
  }
}
